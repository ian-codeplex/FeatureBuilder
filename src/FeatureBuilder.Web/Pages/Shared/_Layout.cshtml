<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FeatureBuilder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        github: {
                            DEFAULT: '#24292f',
                            dark: '#1c2128',
                            light: '#f6f8fa',
                            border: '#d0d7de',
                            blue: '#0969da',
                            green: '#1a7f37',
                            red: '#cf222e',
                            purple: '#8250df'
                        }
                    }
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        @@layer utilities {
            .btn-primary {
                @@apply bg-github-blue text-white px-4 py-2 rounded-md font-medium hover:bg-blue-700 transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed;
            }
            .btn-secondary {
                @@apply bg-white text-github border border-github-border px-4 py-2 rounded-md font-medium hover:bg-gray-50 transition-colors duration-200;
            }
            .btn-danger {
                @@apply bg-github-red text-white px-4 py-2 rounded-md font-medium hover:bg-red-700 transition-colors duration-200;
            }
            .form-input {
                @@apply w-full border border-github-border rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-github-blue focus:border-transparent;
            }
            .form-label {
                @@apply block text-sm font-medium text-gray-700 mb-1;
            }
            .card {
                @@apply bg-white border border-github-border rounded-lg shadow-sm;
            }
            .badge-open {
                @@apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-github-green;
            }
            .badge-closed {
                @@apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600;
            }
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
    <header class="bg-github-dark text-white shadow-md">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-14">
                <div class="flex items-center space-x-4">
                    <a asp-page="/Index" class="flex items-center space-x-2 text-white hover:text-gray-200 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.749 0 .268.18.58.688.482A10.019 10.019 0 0022 12c0-5.523-4.477-10-10-10z"/>
                        </svg>
                        <span class="font-semibold text-lg">FeatureBuilder</span>
                    </a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-page="/Dashboard" class="text-gray-300 hover:text-white text-sm transition-colors">Dashboard</a>
                        <a asp-page="/Issues/Create" class="text-gray-300 hover:text-white text-sm transition-colors">New Issue</a>
                    }
                </div>
                <div class="flex items-center space-x-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var avatarUrl = User.FindFirst("urn:github:avatar")?.Value;
                        var userName = User.FindFirst("urn:github:name")?.Value ?? User.Identity?.Name;
                        <div class="flex items-center space-x-2">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="@userName" class="w-7 h-7 rounded-full border-2 border-gray-500" />
                            }
                            <span class="text-sm text-gray-300">@userName</span>
                        </div>
                        <form asp-page="/Account/Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-sm text-gray-300 hover:text-white transition-colors">Sign out</button>
                        </form>
                    }
                    else
                    {
                        <a asp-page="/Login" class="text-sm btn-primary text-sm py-1.5">Sign in with GitHub</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
        @RenderBody()
    </main>

    <footer class="bg-github-dark text-gray-400 py-4 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm">
            <p>&copy; @DateTime.Now.Year FeatureBuilder &mdash; Built with ASP.NET Core &amp; Tailwind CSS</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>