@page
@model FeatureBuilder.Web.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-github">Issues Dashboard</h1>
            <p class="text-gray-500 mt-1">Issues you've created across your repositories</p>
        </div>
        <a asp-page="/Issues/Create" class="btn-primary flex items-center space-x-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            <span>New Issue</span>
        </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="card p-4">
            <div class="flex items-center space-x-3">
                <div class="p-2 bg-green-100 rounded-lg">
                    <svg class="w-5 h-5 text-github-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-gray-500">Open Issues</p>
                    <p class="text-2xl font-bold text-github">@Model.OpenCount</p>
                </div>
            </div>
        </div>
        <div class="card p-4">
            <div class="flex items-center space-x-3">
                <div class="p-2 bg-gray-100 rounded-lg">
                    <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-gray-500">Closed Issues</p>
                    <p class="text-2xl font-bold text-github">@Model.ClosedCount</p>
                </div>
            </div>
        </div>
        <div class="card p-4">
            <div class="flex items-center space-x-3">
                <div class="p-2 bg-blue-100 rounded-lg">
                    <svg class="w-5 h-5 text-github-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-gray-500">Total Issues</p>
                    <p class="text-2xl font-bold text-github">@Model.Issues.Count</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="card">
        <div class="flex items-center space-x-4 p-4 border-b border-github-border">
            <a asp-page="/Dashboard" asp-route-filter="all"
               class="@(Model.Filter == "all" ? "font-semibold text-github" : "text-gray-500 hover:text-github") text-sm transition-colors">
                All (@Model.Issues.Count)
            </a>
            <a asp-page="/Dashboard" asp-route-filter="open"
               class="@(Model.Filter == "open" ? "font-semibold text-github-green" : "text-gray-500 hover:text-github") text-sm transition-colors flex items-center space-x-1">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span>Open (@Model.OpenCount)</span>
            </a>
            <a asp-page="/Dashboard" asp-route-filter="closed"
               class="@(Model.Filter == "closed" ? "font-semibold text-gray-600" : "text-gray-500 hover:text-github") text-sm transition-colors flex items-center space-x-1">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span>Closed (@Model.ClosedCount)</span>
            </a>
        </div>

        @if (!Model.FilteredIssues.Any())
        {
            <div class="flex flex-col items-center justify-center py-16 text-center">
                <svg class="w-12 h-12 text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                <p class="text-gray-500 font-medium">No issues found</p>
                <p class="text-gray-400 text-sm mt-1">Create your first issue to get started</p>
                <a asp-page="/Issues/Create" class="btn-primary mt-4">Create Issue</a>
            </div>
        }
        else
        {
            <ul class="divide-y divide-github-border">
                @foreach (var issue in Model.FilteredIssues)
                {
                    <li class="p-4 hover:bg-gray-50 transition-colors">
                        <div class="flex items-start space-x-3">
                            <div class="mt-1">
                                @if (issue.State == "open")
                                {
                                    <svg class="w-5 h-5 text-github-green" viewBox="0 0 16 16" fill="currentColor">
                                        <path d="M8 9.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"/>
                                        <path fill-rule="evenodd" d="M8 0a8 8 0 100 16A8 8 0 008 0zM1.5 8a6.5 6.5 0 1113 0 6.5 6.5 0 01-13 0z"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg class="w-5 h-5 text-github-purple" viewBox="0 0 16 16" fill="currentColor">
                                        <path d="M11.28 6.78a.75.75 0 00-1.06-1.06L7.25 8.69 5.78 7.22a.75.75 0 00-1.06 1.06l2 2a.75.75 0 001.06 0l3.5-3.5z"/>
                                        <path fill-rule="evenodd" d="M16 8A8 8 0 110 8a8 8 0 0116 0zm-1.5 0a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0z"/>
                                    </svg>
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center space-x-2 flex-wrap gap-y-1">
                                    <a href="@issue.HtmlUrl" target="_blank" rel="noopener noreferrer"
                                       class="font-semibold text-github hover:text-github-blue transition-colors text-sm">
                                        @issue.Title
                                    </a>
                                    @foreach (var label in issue.Labels.Take(3))
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">@label</span>
                                    }
                                </div>
                                <div class="flex items-center space-x-3 mt-1 text-xs text-gray-500">
                                    <span>
                                        <a asp-page="/Issues/Create" asp-route-repo="@issue.RepositoryFullName"
                                           class="font-medium text-github-blue hover:underline">@issue.RepositoryFullName</a>
                                        #@issue.Number
                                    </span>
                                    <span>Opened @issue.CreatedAt.ToString("MMM d, yyyy")</span>
                                    @if (issue.CommentsCount > 0)
                                    {
                                        <span class="flex items-center space-x-1">
                                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                                            </svg>
                                            <span>@issue.CommentsCount</span>
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="text-right">
                                <a href="@issue.HtmlUrl" target="_blank" rel="noopener noreferrer"
                                   class="text-xs text-gray-400 hover:text-github-blue transition-colors">
                                    View on GitHub ↗
                                </a>
                            </div>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>
